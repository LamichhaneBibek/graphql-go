type User {
  id: ID!
  name: String!
  email: String!
  createdAt: Time!
}

type AuthResponse {
  token: String!
  user: User!
}

input RegisterInput {
  name: String!
  email: String!
  password: String!
}

input LoginInput {
  email: String!
  password: String!
}

type Query {
  users: [User!]!
  user(id: ID!): User
  me: User!
}

type Mutation {
  register(input: RegisterInput!): AuthResponse!
  login(input: LoginInput!): AuthResponse!
}
