type User {
  id: ID!
  name: String!
  email: String!
}

type AuthResponse {
  token: String!
  user: User!
}

type Query {
  users: [User!]!
}

type Mutation {
  register(
    name: String!
    email: String!
    password: String!
  ): AuthResponse!

  login(
    email: String!
    password: String!
  ): AuthResponse!
}